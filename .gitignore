# --- IDE / Éditeurs ---
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# --- Système ---
.DS_Store
Thumbs.db
desktop.ini

# --- Fichiers uploadés ---
ag-backend/uploads/
